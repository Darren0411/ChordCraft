{
  "manifest_version": 3,
  "name": "ChordCraft",
  "version": "1.0",
  "description": "Customize Ultimate Guitar chord sheets",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://tabs.ultimate-guitar.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://tabs.ultimate-guitar.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",

    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}